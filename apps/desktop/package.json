{
  "name": "@openclawdex/desktop",
  "private": true,
  "version": "0.6.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsup && electron .",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dist": "npx electron-builder --mac",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.113",
    "@libsql/client": "^0.17.2",
    "@openclawdex/shared": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "electron-updater": "^6.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.30.4",
    "electron": "41.2.0",
    "electron-builder": "^25.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.openclawdex.app",
    "productName": "OpenClawdex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "web/**/*",
      "drizzle/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": {
        "teamId": "39NAAC43GR"
      }
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "alekseyrozh",
      "repo": "openclawdex"
    }
  }
}
